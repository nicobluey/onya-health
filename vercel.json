{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)\\.(webp|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|otf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index?__route=$1"
    },
    {
      "src": "/doctor/login/?$",
      "dest": "/doctor/login/index.html"
    },
    {
      "src": "/doctor/queue/?$",
      "dest": "/doctor/queue/index.html"
    },
    {
      "src": "/doctor/review/?$",
      "dest": "/doctor/review/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
